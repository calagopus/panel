    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^10.1.0",
    "globals": "^17.7.0",
    "monaco-editor": "^0.55.1",
    "tsx": "^4.23.1",
    "typedoc": "^0.28.20",
    "typedoc-plugin-rename-defaults": "^0.7.3",
    "typedoc-plugin-zod": "^1.4.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vite-multiple-assets": "^2.2.6",
    "vite-plugin-static-copy": "^4.1.1"
  }
}
