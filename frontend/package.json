    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "semver": "^7.8.5",
    "shared": "workspace:*",
    "svg-country-flags": "^1.2.10",
    "tailwindcss": "^4.3.3",
    "tzdata": "^1.0.50",
    "uuid": "^14.0.1",
    "y-monaco": "^0.1.6",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.31",
    "zod": "^4.4.3",
    "zustand": "^5.0.14",
    "zustand-utils": "^2.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
