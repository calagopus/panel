    "deepmerge-ts": "^7.1.5",
    "events": "^3.3.0",
    "highlight.js": "^11.11.1",
    "history": "^5.3.0",
    "ignore": "^7.0.6",
    "immer": "^11.1.15",
    "js-yaml": "^5.2.1",
    "mantine-form-zod-resolver": "^1.3.0",
    "motion": "^12.42.2",
    "object-deep-merge": "^2.0.1",
    "pathe": "^2.0.3",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-avatar-editor": "^15.1.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.7",
